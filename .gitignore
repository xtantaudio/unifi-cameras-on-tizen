# secrets & certs — NEVER commit
tools/certs/
tools/token.json
**/*.p12
**/*.key.pem
**/*.csr
**/*.crt
**/*.cer
**/token.json

# user config (contains camera URLs, possibly credentials)
restreamer/config.json

# app runtime config (your restreamer's host/IP) — same pattern as restreamer/config.json:
# the template is committed, your edited copy never is. Previously config.js itself was
# tracked, which meant setting your real host dirtied the tree and could be committed by
# accident; ignoring it makes that impossible rather than merely discouraged.
app/js/config.js

# build artifacts
app/*.wgt
app/.buildResult/
app/.manifest.tmp
app/author-signature.xml
app/signature1.xml

# restreamer runtime
restreamer/hls/
restreamer/logs/

# os
.DS_Store

# go2rtc — generated config (holds camera URLs) + downloaded binary
restreamer/go2rtc.yaml
restreamer/go2rtc
restreamer/go2rtc.exe
